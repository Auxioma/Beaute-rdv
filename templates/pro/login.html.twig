{% extends 'layouts/auth.html.twig' %}
{% trans_default_domain 'messages' %}
{% set page_title = 'auth.login_pro.page_title'|trans %}
{% set meta_description = 'auth.login_pro.meta_description'|trans %}
{% set body_class = 'bm-page-auth-pro' %}
{% set main_class = 'bm-auth-main' %}

{% block body %}
<section aria-labelledby="loginTitle" class="container bm-container">
<div class="bm-auth-shell">
<div class="row g-0 align-items-stretch">
<div class="col-xl-6">
<div class="bm-auth-visual">
<div class="bm-auth-visual-inner">
<span class="bm-auth-brand-mark"><i class="bi bi-gem"></i> {{ 'auth.login_pro.brand'|trans }}</span>
<div class="bm-auth-visual-copy">
<h1 id="loginTitle">{{ 'auth.login_pro.title'|trans }}</h1>
<p>{{ 'auth.login_pro.subtitle'|trans }}</p>
<div aria-label="Avantages espace professionnel" class="bm-auth-proof-row">
<div class="bm-auth-proof"><strong>{{ 'auth.login_pro.benefit_1'|trans }}</strong><span>{{ 'auth.login_pro.benefit_1_text'|trans }}</span></div>
<div class="bm-auth-proof"><strong>{{ 'auth.login_pro.benefit_2'|trans }}</strong><span>{{ 'auth.login_pro.benefit_2_text'|trans }}</span></div>
<div class="bm-auth-proof"><strong>{{ 'auth.login_pro.benefit_3'|trans }}</strong><span>{{ 'auth.login_pro.benefit_3_text'|trans }}</span></div>
</div>
</div>
</div>
</div>
</div>
<div class="col-xl-6">
<div class="bm-auth-panel">
<div class="bm-auth-card">
<div class="bm-auth-card-head">
<span class="bm-auth-badge"><i class="bi bi-shield-check"></i> {{ 'auth.login_pro.badge'|trans }}</span>
<h2>{{ 'auth.login_pro.heading'|trans }}</h2>
<p>{{ 'auth.login_pro.description'|trans }}</p>
</div>
{{ include('components/_flash_messages.html.twig') }}
{% if error %}
<div class="alert alert-danger mb-3" role="alert">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
{% endif %}
<form action="{{ locale_path('app_login_pro', {'_locale': app.request.locale}) }}" class="bm-auth-form" method="post" novalidate="">
<div class="bm-auth-form-fields">
<div>
<label class="form-label bm-label" for="loginEmail">{{ 'auth.common.pro_email'|trans }}</label>
<div class="bm-auth-field">
<i class="bi bi-envelope"></i>
<input autocomplete="email" class="form-control bm-auth-input" id="loginEmail" name="email" placeholder="{{ 'auth.login_pro.email_placeholder'|trans }}" required="" type="email" value="{{ last_username|default('') }}"/>
</div>
</div>
<div>
<label class="form-label bm-label" for="loginPassword">{{ 'auth.common.password'|trans }}</label>
<div class="bm-auth-field">
<i class="bi bi-lock"></i>
<input autocomplete="current-password" class="form-control bm-auth-input" id="loginPassword" name="password" placeholder="{{ 'auth.login_user.password_placeholder'|trans }}" required="" type="password"/>
</div>
</div>
</div>
<input name="_csrf_token" type="hidden" value="{{ csrf_token('authenticate') }}"/>
<div class="bm-auth-options">
<label class="bm-auth-check" for="rememberMe">
<input class="form-check-input" id="rememberMe" name="_remember_me" type="checkbox"/>
<span>{{ 'auth.login_user.remember_me'|trans }}</span>
</label>
<a class="bm-auth-link" href="{{ locale_path('app_forgot_password') }}">{{ 'auth.login_user.forgot_password'|trans }}</a>
</div>
<button class="btn bm-btn bm-btn-primary bm-auth-submit" type="submit">{{ 'auth.login_user.submit'|trans }}</button>
</form>
<div class="bm-auth-tail">
<div class="bm-auth-divider">{{ 'auth.common.or'|trans }}</div>
<div class="bm-auth-secondary-action">
<div>
<strong>{{ 'auth.login_pro.cta_title'|trans }}</strong>
<span>{{ 'auth.login_pro.cta_text'|trans }}</span>
</div>
<a class="btn bm-btn bm-btn-outline" href="{{ locale_path('app_register_pro') }}">{{ 'auth.login_pro.cta_button'|trans }}</a>
</div>
<div class="bm-auth-help-grid">
<div class="bm-auth-help-card"><i class="bi bi-question-circle"></i><div><strong>{{ 'auth.login_pro.help_1_title'|trans }}</strong><span>{{ 'auth.login_pro.help_1_text'|trans }}</span></div></div>
<div class="bm-auth-help-card"><i class="bi bi-stars"></i><div><strong>{{ 'auth.login_pro.help_2_title'|trans }}</strong><span>{{ 'auth.login_pro.help_2_text'|trans }}</span></div></div>
</div>
<div class="bm-auth-note">
<i class="bi bi-info-circle"></i>
<div><strong>{{ 'auth.common.tip'|trans }}</strong> {{ 'auth.login_pro.tip_text'|trans }}</div>
</div>
</div>
</div>
</div>
</div>
</div>
</div>
</section>
{% endblock %}
