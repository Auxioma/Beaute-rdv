{% extends 'layouts/auth.html.twig' %}
{% trans_default_domain 'messages' %}
{% set page_title = 'auth.register_user.page_title'|trans %}
{% set meta_description = 'auth.register_user.meta_description'|trans %}
{% set body_class = 'bm-page-auth-user' %}
{% set main_class = 'bm-auth-main bm-auth-main-user' %}

{% block body %}
<section aria-labelledby="registerUserTitle" class="container bm-container">
<div class="bm-auth-shell bm-auth-shell-user">
<div class="row g-0 align-items-stretch">
<div class="col-xl-6">
<div class="bm-auth-visual bm-auth-visual-user">
<div class="bm-auth-visual-inner">
<span class="bm-auth-brand-mark"><i class="bi bi-heart"></i> {{ 'auth.register_user.brand'|trans }}</span>
<div class="bm-auth-visual-copy">
<h1 id="registerUserTitle">{{ 'auth.register_user.title'|trans }}</h1>
<p>{{ 'auth.register_user.subtitle'|trans }}</p>
<div aria-label="Avantages compte client" class="bm-auth-proof-row bm-auth-proof-row-user">
<div class="bm-auth-proof"><strong>{{ 'auth.register_user.benefit_1'|trans }}</strong><span>{{ 'auth.register_user.benefit_1_text'|trans }}</span></div>
<div class="bm-auth-proof"><strong>{{ 'auth.register_user.benefit_2'|trans }}</strong><span>{{ 'auth.register_user.benefit_2_text'|trans }}</span></div>
<div class="bm-auth-proof"><strong>{{ 'auth.register_user.benefit_3'|trans }}</strong><span>{{ 'auth.register_user.benefit_3_text'|trans }}</span></div>
</div>
</div>
</div>
</div>
</div>
<div class="col-xl-6">
<div class="bm-auth-panel">
<div class="bm-auth-card bm-auth-card-user">
<div class="bm-auth-card-head">
<span class="bm-auth-badge"><i class="bi bi-person-check"></i> {{ 'auth.register_user.badge'|trans }}</span>
<h2>{{ 'auth.register_user.heading'|trans }}</h2>
<p>{{ 'auth.register_user.description'|trans }}</p>
</div>
{{ include('components/_flash_messages.html.twig') }}
{{ form_start(registrationForm, {attr: {class: 'bm-auth-form', novalidate: 'novalidate'}}) }}
{{ form_errors(registrationForm) }}
<div class="row g-3 bm-auth-form-grid">
<div class="col-md-6">
<label class="form-label bm-label" for="{{ registrationForm.firstname.vars.id }}">{{ 'auth.common.firstname'|trans }}</label>
<div class="bm-auth-field"><i class="bi bi-person"></i>{{ form_widget(registrationForm.firstname, {attr: {autocomplete: 'given-name', class: 'form-control bm-auth-input', placeholder: 'auth.register_user.firstname_placeholder'|trans}}) }}</div>
{{ form_errors(registrationForm.firstname) }}
</div>
<div class="col-md-6">
<label class="form-label bm-label" for="{{ registrationForm.lastname.vars.id }}">{{ 'auth.common.lastname'|trans }}</label>
<div class="bm-auth-field"><i class="bi bi-person"></i>{{ form_widget(registrationForm.lastname, {attr: {autocomplete: 'family-name', class: 'form-control bm-auth-input', placeholder: 'auth.register_user.lastname_placeholder'|trans}}) }}</div>
{{ form_errors(registrationForm.lastname) }}
</div>
<div class="col-12">
<label class="form-label bm-label" for="{{ registrationForm.email.vars.id }}">{{ 'auth.common.email'|trans }}</label>
<div class="bm-auth-field"><i class="bi bi-envelope"></i>{{ form_widget(registrationForm.email, {attr: {autocomplete: 'email', class: 'form-control bm-auth-input', placeholder: 'auth.login_user.email_placeholder'|trans}}) }}</div>
{{ form_errors(registrationForm.email) }}
</div>
<div class="col-md-6">
<label class="form-label bm-label" for="{{ registrationForm.plainPassword.vars.id }}">{{ 'auth.common.password'|trans }}</label>
<div class="bm-auth-field"><i class="bi bi-lock"></i>{{ form_widget(registrationForm.plainPassword, {attr: {autocomplete: 'new-password', class: 'form-control bm-auth-input', placeholder: 'auth.register_user.password_placeholder'|trans}}) }}</div>
{{ form_errors(registrationForm.plainPassword) }}
</div>
<div class="col-md-6">
<label class="form-label bm-label" for="{{ registrationForm.defaultCity.vars.id }}">{{ 'auth.common.primary_city'|trans }}</label>
<div class="bm-auth-field"><i class="bi bi-geo-alt"></i>{{ form_widget(registrationForm.defaultCity, {attr: {autocomplete: 'address-level2', class: 'form-control bm-auth-input', placeholder: 'auth.register_user.city_placeholder'|trans}}) }}</div>
{{ form_errors(registrationForm.defaultCity) }}
</div>
</div>
<label class="bm-auth-check bm-auth-check-large" for="{{ registrationForm.marketingEmailConsent.vars.id }}">
{{ form_widget(registrationForm.marketingEmailConsent, {attr: {class: 'form-check-input'}}) }}
<span>{{ 'auth.register_user.marketing_optin'|trans }}</span>
</label>
{{ form_errors(registrationForm.marketingEmailConsent) }}
<label class="bm-auth-check bm-auth-check-large" for="{{ registrationForm.agreeTerms.vars.id }}">
{{ form_widget(registrationForm.agreeTerms, {attr: {class: 'form-check-input'}}) }}
<span>{{ 'auth.register_user.agree_terms'|trans }}</span>
</label>
{{ form_errors(registrationForm.agreeTerms) }}
<button class="btn bm-btn bm-btn-primary bm-auth-submit" type="submit">{{ 'auth.register_user.submit'|trans }}</button>
{{ form_end(registrationForm) }}
<div class="bm-auth-tail">
<div class="bm-auth-divider">{{ 'auth.common.or'|trans }}</div>
<div class="bm-auth-social-grid">
<a aria-disabled="true" class="bm-auth-social-btn" href="#"><i class="bi bi-google"></i> {{ 'auth.social.google'|trans }}</a>
<a aria-disabled="true" class="bm-auth-social-btn" href="#"><i class="bi bi-apple"></i> {{ 'auth.social.apple'|trans }}</a>
</div>
<div class="bm-auth-mini-footer">
<span>{{ 'auth.register_user.footer_title'|trans }}</span>
<a href="{{ locale_path('app_login_user') }}">{{ 'auth.login_user.submit'|trans }}</a>
</div>
<div class="bm-auth-note">
<i class="bi bi-shield-check"></i>
<div><strong>{{ 'auth.register_user.note_title'|trans }}</strong> {{ 'auth.register_user.note_text'|trans }}</div>
</div>
</div>
</div>
</div>
</div>
</div>
</div>
</section>
{% endblock %}
