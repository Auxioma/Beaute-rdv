{% extends 'layouts/auth.html.twig' %}
{% trans_default_domain 'messages' %}
{% set page_title = 'auth.forgot_user.page_title'|trans %}
{% set meta_description = 'auth.forgot_user.meta_description'|trans %}
{% set body_class = 'bm-page-auth-user' %}
{% set main_class = 'bm-auth-main bm-auth-main-user' %}

{% block body %}
<section aria-labelledby="forgotUserTitle" class="container bm-container">
<div class="bm-auth-compact-shell">
<div class="bm-auth-shell bm-auth-shell-user">
<div class="row g-0 align-items-stretch">
<div class="col-lg-5">
<div class="bm-auth-visual bm-auth-visual-user bm-auth-visual-user-reset">
<div class="bm-auth-visual-inner">
<span class="bm-auth-brand-mark"><i class="bi bi-key"></i> {{ 'auth.forgot_user.brand'|trans }}</span>
<div class="bm-auth-visual-copy">
<h1>{{ 'auth.forgot_user.title'|trans }}</h1>
<p>{{ 'auth.forgot_user.subtitle'|trans }}</p>
</div>
</div>
</div>
</div>
<div class="col-lg-7">
<div class="bm-auth-panel">
<div class="bm-auth-compact-card">
<div class="bm-auth-card-head">
<span class="bm-auth-badge"><i class="bi bi-envelope-check"></i> {{ 'auth.forgot_user.badge'|trans }}</span>
<h2 id="forgotUserTitle">{{ 'auth.forgot_user.heading'|trans }}</h2>
<p>{{ 'auth.forgot_user.description'|trans }}</p>
</div>
{{ include('components/_flash_messages.html.twig') }}
{{ form_start(requestForm, {attr: {class: 'bm-auth-form', novalidate: 'novalidate'}}) }}
{{ form_errors(requestForm) }}
<div class="mb-3">
<label class="form-label bm-label" for="{{ requestForm.email.vars.id }}">{{ 'auth.common.email'|trans }}</label>
<div class="bm-auth-field"><i class="bi bi-envelope"></i>{{ form_widget(requestForm.email, {attr: {class: 'form-control bm-auth-input', id: 'resetEmail', placeholder: 'auth.login_user.email_placeholder'|trans}}) }}</div>
{{ form_errors(requestForm.email) }}
</div>
<button class="btn bm-btn bm-btn-primary bm-auth-submit" type="submit">{{ 'auth.forgot_user.submit'|trans }}</button>
{{ form_end(requestForm) }}
<div class="bm-auth-steps">
<div class="bm-auth-step"><span>1</span><div><strong>{{ 'auth.forgot_user.step_1_title'|trans }}</strong><p>{{ 'auth.forgot_user.step_1_text'|trans }}</p></div></div>
<div class="bm-auth-step"><span>2</span><div><strong>{{ 'auth.forgot_user.step_2_title'|trans }}</strong><p>{{ 'auth.forgot_user.step_2_text'|trans }}</p></div></div>
<div class="bm-auth-step"><span>3</span><div><strong>{{ 'auth.forgot_user.step_3_title'|trans }}</strong><p>{{ 'auth.forgot_user.step_3_text'|trans }}</p></div></div>
</div>
<div class="bm-auth-secondary-action bm-auth-secondary-action-user">
<div><strong>{{ 'auth.forgot_user.cta_title'|trans }}</strong><span>{{ 'auth.forgot_user.cta_text'|trans }}</span></div>
<a class="btn bm-btn bm-btn-outline" href="{{ locale_path('app_login_user') }}">{{ 'auth.login_user.submit'|trans }}</a>
</div>
<div class="bm-auth-note">
<i class="bi bi-info-circle"></i>
<div><strong>{{ 'auth.common.good_to_know'|trans }}</strong> {{ 'auth.forgot_user.note_text'|trans }}</div>
</div>
</div>
</div>
</div>
</div>
</div>
</div>
</section>
{% endblock %}
