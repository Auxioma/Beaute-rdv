{% extends 'layouts/auth.html.twig' %}
{% trans_default_domain 'messages' %}
{% set page_title = 'auth.login_user.page_title'|trans %}
{% set meta_description = 'auth.login_user.meta_description'|trans %}
{% set body_class = 'bm-page-auth-user' %}
{% set main_class = 'bm-auth-main bm-auth-main-user' %}

{% block body %}
<section aria-labelledby="loginUserTitle" class="container bm-container">
<div class="bm-auth-shell bm-auth-shell-user">
<div class="row g-0 align-items-stretch">
<div class="col-xl-6">
<div class="bm-auth-visual bm-auth-visual-user bm-auth-visual-user-login">
<div class="bm-auth-visual-inner">
<span class="bm-auth-brand-mark"><i class="bi bi-stars"></i> {{ 'auth.login_user.brand'|trans }}</span>
<div class="bm-auth-visual-copy">
<h1 id="loginUserTitle">{{ 'auth.login_user.title'|trans }}</h1>
<p>{{ 'auth.login_user.subtitle'|trans }}</p>
<div class="bm-user-mini-benefits">
<div><i class="bi bi-calendar2-check"></i><span>{{ 'auth.login_user.benefit_1'|trans }}</span></div>
<div><i class="bi bi-heart"></i><span>{{ 'auth.login_user.benefit_2'|trans }}</span></div>
<div><i class="bi bi-bell"></i><span>{{ 'auth.login_user.benefit_3'|trans }}</span></div>
</div>
</div>
</div>
</div>
</div>
<div class="col-xl-6">
<div class="bm-auth-panel">
<div class="bm-auth-card bm-auth-card-user">
<div class="bm-auth-card-head">
<span class="bm-auth-badge"><i class="bi bi-shield-lock"></i> {{ 'auth.login_user.badge'|trans }}</span>
<h2>{{ 'auth.login_user.heading'|trans }}</h2>
<p>{{ 'auth.login_user.description'|trans }}</p>
</div>
{{ include('components/_flash_messages.html.twig') }}
{% if error %}
<div class="alert alert-danger mb-3" role="alert">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
{% endif %}
<form action="{{ locale_path('app_login_user', {'_locale': app.request.locale}) }}" class="bm-auth-form" method="post" novalidate="">
<div class="bm-auth-form-fields">
<div>
<label class="form-label bm-label" for="loginEmail">{{ 'auth.common.email'|trans }}</label>
<div class="bm-auth-field"><i class="bi bi-envelope"></i><input autocomplete="email" class="form-control bm-auth-input" id="loginEmail" name="email" placeholder="{{ 'auth.login_user.email_placeholder'|trans }}" required="" type="email" value="{{ last_username|default('') }}"/></div>
</div>
<div>
<label class="form-label bm-label" for="loginPassword">{{ 'auth.common.password'|trans }}</label>
<div class="bm-auth-field"><i class="bi bi-lock"></i><input autocomplete="current-password" class="form-control bm-auth-input" id="loginPassword" name="password" placeholder="{{ 'auth.login_user.password_placeholder'|trans }}" required="" type="password"/></div>
</div>
</div>
<input name="_csrf_token" type="hidden" value="{{ csrf_token('authenticate') }}"/>
<div class="bm-auth-options">
<label class="bm-auth-check" for="rememberUser"><input class="form-check-input" id="rememberUser" name="_remember_me" type="checkbox"/><span>{{ 'auth.login_user.remember_me'|trans }}</span></label>
<a class="bm-auth-link" href="{{ locale_path('app_forgot_password_user') }}">{{ 'auth.login_user.forgot_password'|trans }}</a>
</div>
<button class="btn bm-btn bm-btn-primary bm-auth-submit" type="submit">{{ 'auth.login_user.submit'|trans }}</button>
</form>
<div class="bm-auth-tail">
<div class="bm-auth-divider">{{ 'auth.common.or'|trans }}</div>
<div class="bm-auth-social-grid">
<a class="bm-auth-social-btn" href="#"><i class="bi bi-google"></i> {{ 'auth.social.google'|trans }}</a>
<a class="bm-auth-social-btn" href="#"><i class="bi bi-apple"></i> {{ 'auth.social.apple'|trans }}</a>
</div>
<div class="bm-auth-secondary-action bm-auth-secondary-action-user">
<div><strong>{{ 'auth.login_user.cta_title'|trans }}</strong><span>{{ 'auth.login_user.cta_text'|trans }}</span></div>
<a class="btn bm-btn bm-btn-outline" href="{{ locale_path('app_register_user') }}">{{ 'auth.login_user.cta_button'|trans }}</a>
</div>
<div class="bm-auth-help-grid">
<div class="bm-auth-help-card"><i class="bi bi-calendar-heart"></i><div><strong>{{ 'auth.login_user.help_1_title'|trans }}</strong><span>{{ 'auth.login_user.help_1_text'|trans }}</span></div></div>
<div class="bm-auth-help-card"><i class="bi bi-gem"></i><div><strong>{{ 'auth.login_user.help_2_title'|trans }}</strong><span>{{ 'auth.login_user.help_2_text'|trans }}</span></div></div>
</div>
</div>
</div>
</div>
</div>
</div>
</div>
</section>
{% endblock %}
