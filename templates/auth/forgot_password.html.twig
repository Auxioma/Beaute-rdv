{% extends 'layouts/auth.html.twig' %}
{% trans_default_domain 'messages' %}
{% set page_title = 'auth.forgot_pro.page_title'|trans %}
{% set meta_description = 'auth.forgot_pro.meta_description'|trans %}
{% set body_class = 'bm-page-auth-pro' %}
{% set main_class = 'bm-auth-main' %}

{% block body %}
<section aria-labelledby="forgotTitle" class="container bm-container">
<div class="bm-auth-compact-shell">
<div class="bm-auth-shell">
<div class="row g-0 align-items-stretch">
<div class="col-lg-5">
<div class="bm-auth-visual">
<div class="bm-auth-visual-inner">
<span class="bm-auth-brand-mark"><i class="bi bi-key"></i> {{ 'auth.forgot_pro.brand'|trans }}</span>
<div class="bm-auth-visual-copy">
<h1>{{ 'auth.forgot_pro.title'|trans }}</h1>
<p>{{ 'auth.forgot_pro.subtitle'|trans }}</p>
</div>
</div>
</div>
</div>
<div class="col-lg-7">
<div class="bm-auth-panel">
<div class="bm-auth-compact-card">
<div class="bm-auth-card-head">
<span class="bm-auth-badge"><i class="bi bi-envelope-check"></i> {{ 'auth.forgot_pro.badge'|trans }}</span>
<h2 id="forgotTitle">{{ 'auth.forgot_pro.heading'|trans }}</h2>
<p>{{ 'auth.forgot_pro.description'|trans }}</p>
</div>
{{ include('components/_flash_messages.html.twig') }}
{{ form_start(requestForm, {attr: {class: 'bm-auth-form', novalidate: 'novalidate'}}) }}
{{ form_errors(requestForm) }}
<div class="mb-3">
<label class="form-label bm-label" for="{{ requestForm.email.vars.id }}">{{ 'auth.common.pro_email'|trans }}</label>
<div class="bm-auth-field">
<i class="bi bi-envelope"></i>
{{ form_widget(requestForm.email, {attr: {class: 'form-control bm-auth-input', id: 'resetEmail', placeholder: 'auth.login_pro.email_placeholder'|trans}}) }}
</div>
{{ form_errors(requestForm.email) }}
</div>
<button class="btn bm-btn bm-btn-primary bm-auth-submit" type="submit">{{ 'auth.forgot_pro.submit'|trans }}</button>
{{ form_end(requestForm) }}
<div class="bm-auth-note">
<i class="bi bi-shield-lock"></i>
<div><strong>{{ 'auth.common.security_label'|trans }}</strong> {{ 'auth.forgot_pro.note_text'|trans }}</div>
</div>
<div aria-label="{{ 'auth.forgot_pro.steps_aria'|trans }}" class="bm-auth-steps">
<div class="bm-auth-step"><span>1</span><div><strong>{{ 'auth.forgot_pro.step_1_title'|trans }}</strong><p>{{ 'auth.forgot_pro.step_1_text'|trans }}</p></div></div>
<div class="bm-auth-step"><span>2</span><div><strong>{{ 'auth.forgot_pro.step_2_title'|trans }}</strong><p>{{ 'auth.forgot_pro.step_2_text'|trans }}</p></div></div>
<div class="bm-auth-step"><span>3</span><div><strong>{{ 'auth.forgot_pro.step_3_title'|trans }}</strong><p>{{ 'auth.forgot_pro.step_3_text'|trans }}</p></div></div>
</div>
<div class="bm-auth-mini-footer">
<span>{{ 'auth.forgot_pro.cta_title'|trans }}</span>
<a href="{{ locale_path('app_login_pro') }}">{{ 'auth.reset.back_to_login'|trans }}</a>
</div>
</div>
</div>
</div>
</div>
</div>
</div>
</section>
{% endblock %}
