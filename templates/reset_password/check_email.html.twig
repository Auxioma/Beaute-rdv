{% extends 'layouts/auth.html.twig' %}
{% trans_default_domain 'messages' %}
{% set body_class = is_pro ? 'bm-page-auth-pro' : 'bm-page-auth-user' %}
{% set main_class = is_pro ? 'bm-auth-main' : 'bm-auth-main bm-auth-main-user' %}
{% set page_title = is_pro ? 'auth.check_email_pro.page_title'|trans : 'auth.check_email_user.page_title'|trans %}

{% block body %}
<section class="container bm-container" aria-labelledby="checkEmailTitle">
    <div class="bm-auth-compact-shell">
        <div class="bm-auth-shell {{ is_pro ? '' : 'bm-auth-shell-user' }}">
            <div class="row g-0 align-items-stretch">
                <div class="col-lg-5">
                    <div class="bm-auth-visual {{ is_pro ? '' : 'bm-auth-visual-user' }}">
                        <div class="bm-auth-visual-inner">
                            <span class="bm-auth-brand-mark"><i class="bi bi-envelope-paper-heart"></i> {{ (is_pro ? 'auth.forgot_pro.brand' : 'auth.forgot_user.brand')|trans }}</span>
                            <div class="bm-auth-visual-copy">
                                <h1 id="checkEmailTitle">{{ 'auth.check_email.title'|trans }}</h1>
                                <p>{{ 'auth.check_email.subtitle'|trans }}</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-7">
                    <div class="bm-auth-panel">
                        <div class="bm-auth-compact-card">
                            {{ include('components/_flash_messages.html.twig') }}
                            <div class="bm-auth-card-head">
                                <span class="bm-auth-badge"><i class="bi bi-shield-check"></i> {{ 'auth.check_email.badge'|trans }}</span>
                                <h2>{{ 'auth.check_email.heading'|trans }}</h2>
                                <p>{{ 'auth.check_email.expiration_prefix'|trans }} {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.</p>
                            </div>
                            <div class="bm-auth-note">
                                <i class="bi bi-info-circle"></i>
                                <div><strong>{{ 'auth.check_email.note_title'|trans }}</strong> {{ 'auth.check_email.note_text'|trans }}</div>
                            </div>
                            <div class="bm-auth-secondary-action {{ is_pro ? '' : 'bm-auth-secondary-action-user' }}">
                                <div><strong>{{ 'auth.check_email.cta_title'|trans }}</strong><span>{{ 'auth.check_email.cta_text'|trans }}</span></div>
                                <a class="btn bm-btn bm-btn-outline" href="{{ locale_path(forgot_route) }}">{{ 'auth.check_email.cta_button'|trans }}</a>
                            </div>
                            <div class="bm-auth-mini-footer">
                                <span>{{ 'auth.check_email.footer_title'|trans }}</span>
                                <a href="{{ locale_path(login_route) }}">{{ 'auth.reset.back_to_login'|trans }}</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
