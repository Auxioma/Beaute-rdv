{% extends 'layouts/auth.html.twig' %}
{% set body_class = is_pro ? 'bm-page-auth-pro' : 'bm-page-auth-user' %}
{% set main_class = is_pro ? 'bm-auth-main' : 'bm-auth-main bm-auth-main-user' %}
{% set page_title = page_title|default(is_pro ? 'Email envoyé — Belle Maison Pro' : 'Email envoyé — Belle Maison') %}

{% block body %}
<section class="container bm-container" aria-labelledby="checkEmailTitle">
    <div class="bm-auth-compact-shell">
        <div class="bm-auth-shell {{ is_pro ? '' : 'bm-auth-shell-user' }}">
            <div class="row g-0 align-items-stretch">
                <div class="col-lg-5">
                    <div class="bm-auth-visual {{ is_pro ? '' : 'bm-auth-visual-user' }}">
                        <div class="bm-auth-visual-inner">
                            <span class="bm-auth-brand-mark"><i class="bi bi-envelope-paper-heart"></i> {{ is_pro ? 'Espace professionnel' : 'Espace client' }}</span>
                            <div class="bm-auth-visual-copy">
                                <h1 id="checkEmailTitle">Vérifiez votre boîte email.</h1>
                                <p>Si un compte existe, un lien sécurisé vient d’être envoyé pour vous permettre de choisir un nouveau mot de passe.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-7">
                    <div class="bm-auth-panel">
                        <div class="bm-auth-compact-card">
                            {{ include('components/_flash_messages.html.twig') }}
                            <div class="bm-auth-card-head">
                                <span class="bm-auth-badge"><i class="bi bi-shield-check"></i> Email envoyé</span>
                                <h2>Consultez votre messagerie</h2>
                                <p>Le lien de réinitialisation expire {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.</p>
                            </div>
                            <div class="bm-auth-note">
                                <i class="bi bi-info-circle"></i>
                                <div><strong>Vous ne voyez rien ?</strong> Pensez à vérifier vos spams ou à refaire une demande dans quelques minutes.</div>
                            </div>
                            <div class="bm-auth-secondary-action {{ is_pro ? '' : 'bm-auth-secondary-action-user' }}">
                                <div><strong>Besoin d’un nouvel envoi ?</strong><span>Vous pouvez recommencer la procédure si nécessaire.</span></div>
                                <a class="btn bm-btn bm-btn-outline" href="{{ path(forgot_route) }}">Refaire une demande</a>
                            </div>
                            <div class="bm-auth-mini-footer">
                                <span>Vous avez retrouvé votre mot de passe ?</span>
                                <a href="{{ path(login_route) }}">Retour à la connexion</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
