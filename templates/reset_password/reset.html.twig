{% extends 'layouts/auth.html.twig' %}
{% trans_default_domain 'messages' %}
{% set body_class = is_pro ? 'bm-page-auth-pro' : 'bm-page-auth-user' %}
{% set main_class = is_pro ? 'bm-auth-main' : 'bm-auth-main bm-auth-main-user' %}
{% set page_title = is_pro ? 'auth.reset_pro.page_title'|trans : 'auth.reset_user.page_title'|trans %}

{% block body %}
<section class="container bm-container" aria-labelledby="resetPasswordTitle">
    <div class="bm-auth-compact-shell">
        <div class="bm-auth-shell {{ is_pro ? '' : 'bm-auth-shell-user' }}">
            <div class="row g-0 align-items-stretch">
                <div class="col-lg-5">
                    <div class="bm-auth-visual {{ is_pro ? '' : 'bm-auth-visual-user' }}">
                        <div class="bm-auth-visual-inner">
                            <span class="bm-auth-brand-mark"><i class="bi bi-lock"></i> {{ (is_pro ? 'auth.login_pro.brand' : 'auth.login_user.brand')|trans }}</span>
                            <div class="bm-auth-visual-copy">
                                <h1 id="resetPasswordTitle">{{ 'auth.reset.title'|trans }}</h1>
                                <p>{{ 'auth.reset.subtitle'|trans }}</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-7">
                    <div class="bm-auth-panel">
                        <div class="bm-auth-compact-card">
                            {{ include('components/_flash_messages.html.twig') }}
                            <div class="bm-auth-card-head">
                                <span class="bm-auth-badge"><i class="bi bi-key"></i> {{ 'auth.reset.badge'|trans }}</span>
                                <h2>{{ 'auth.reset.heading'|trans }}</h2>
                                <p>{{ 'auth.reset.description'|trans }}</p>
                            </div>
                            {{ form_start(resetForm, {attr: {class: 'bm-auth-form', novalidate: 'novalidate'}}) }}
                            {{ form_errors(resetForm) }}
                            <div class="mb-3">
                                <label class="form-label bm-label" for="{{ resetForm.plainPassword.first.vars.id }}">{{ 'auth.reset.new_password'|trans }}</label>
                                <div class="bm-auth-field"><i class="bi bi-lock"></i>{{ form_widget(resetForm.plainPassword.first, {attr: {class: 'form-control bm-auth-input', placeholder: 'auth.reset.new_password_placeholder'|trans}}) }}</div>
                                {{ form_errors(resetForm.plainPassword.first) }}
                            </div>
                            <div class="mb-3">
                                <label class="form-label bm-label" for="{{ resetForm.plainPassword.second.vars.id }}">{{ 'auth.reset.confirm_password'|trans }}</label>
                                <div class="bm-auth-field"><i class="bi bi-shield-lock"></i>{{ form_widget(resetForm.plainPassword.second, {attr: {class: 'form-control bm-auth-input', placeholder: 'auth.reset.confirm_password_placeholder'|trans}}) }}</div>
                                {{ form_errors(resetForm.plainPassword.second) }}
                            </div>
                            <button class="btn bm-btn bm-btn-primary bm-auth-submit" type="submit">{{ 'auth.reset.submit'|trans }}</button>
                            {{ form_end(resetForm) }}
                            <div class="bm-auth-mini-footer">
                                <span>{{ 'auth.reset.footer_title'|trans }}</span>
                                <a href="{{ locale_path(login_route) }}">{{ 'auth.reset.back_to_login'|trans }}</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
